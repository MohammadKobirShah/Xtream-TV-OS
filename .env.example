# ============================================================
#  XtreamTV IPTV OS — Environment Variables
#  Developer: Kobir Shah
#  Copy to .env and customize before running docker-compose
#    cp .env.example .env
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_NAME=XtreamTV
APP_VERSION=2.0.0
DEVELOPER=Kobir Shah
DEVELOPER_CREDIT="Powered by Kobir Shah"

# ── Ports ────────────────────────────────────────────────────
HTTP_PORT=8080
HTTPS_PORT=8443
REDIS_PORT=6379

# ── Timezone ─────────────────────────────────────────────────
TZ=UTC

# ── PHP ──────────────────────────────────────────────────────
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300
PHP_UPLOAD_MAX_FILESIZE=200M

# ── Database ─────────────────────────────────────────────────
# SQLite path is auto-managed inside storage/
# No credentials needed for SQLite

# ── Default Admin (used only during install) ─────────────────
# CHANGE THESE BEFORE FIRST RUN IN PRODUCTION!
ADMIN_USER=admin
ADMIN_PASS=admin123

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Get your token from: https://one.dash.cloudflare.com → Zero Trust → Tunnels
# NEVER commit the real .env file — keep it in .gitignore!
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
